          },
          "originalAmount": {
            "type": "integer",
            "format": "int64"
          },
          "discountAmount": {
            "type": "integer",
            "format": "int64"
          },
          "payableAmount": {
            "type": "integer",
            "format": "int64"
          },
          "payableAmountLabel": {
            "type": "string"
          },
          "expireAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "SuiteInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "price": {
            "type": "integer",
            "format": "int64"
          },
          "priceLabel": {
            "type": "string"
          }
        }
      },
      "EvaluationSubmitRequest": {
        "required": [
          "score"
        ],
        "type": "object",
        "properties": {
          "orderId": {
            "type": "string"
          },
          "score": {
            "maximum": 5,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "content": {
            "type": "string"
          },
          "anonymous": {
            "type": "boolean"
          }
        }
      },
      "ApiResponseEvaluationSubmitResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/EvaluationSubmitResponse"
          },
          "requestId": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "EvaluationSubmitResponse": {
        "type": "object",
        "properties": {
          "evaluationId": {
            "type": "string"
          },
          "submitted": {
            "type": "boolean"
          }
        }
      },
