        "required": [
          "content"
        ],
        "type": "object",
        "properties": {
          "contactName": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "relatedService": {
            "type": "string"
          },
          "complaintType": {
            "type": "string",
            "enum": [
              "SERVICE_QUALITY",
              "FACILITY_ENVIRONMENT",
              "CATERING_SUGGESTION",
              "OTHER"
            ]
          }
        }
      },
      "ApiResponseComplaintSubmitResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "message": {
            "type": "string"
          },
          "data": {
